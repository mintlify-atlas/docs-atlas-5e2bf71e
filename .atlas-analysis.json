  "keyFeatures": [
    "Ash Framework-based domain modeling",
    "Multi-strategy authentication (password, magic link, remember me)",
    "Email confirmation and password reset",
    "JSON API with OpenAPI/Swagger documentation",
    "PostgreSQL database with migrations",
    "Phoenix LiveView web interface",
    "Token-based authentication with JWT",
    "User account management"
  ],
  "publicApiSurface": [
    "POST /api/json/users (register_with_password)",
    "POST /api/json/auth/sign_in (sign_in_with_password)",
    "POST /api/json/auth/reset_password (request_password_reset_token)",
    "PATCH /api/json/users/:id (reset_password_with_token)",
    "GET /api/json/users/:id (read user)",
    "GET /api/json/swaggerui (OpenAPI documentation)",
    "AshCoffee.Accounts domain",
    "AshCoffee.Accounts.User resource",
    "AshCoffee.Accounts.Token resource"
  ]
}
